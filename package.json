    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
